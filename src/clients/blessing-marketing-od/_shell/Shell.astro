---
// src/clients/blessing-marketing-od/_shell/Shell.astro
// Geteilter Rahmen: Wrapper + Header + Footer + Tokens/Chrome-CSS (global) + Script.
// Home und Subpages wickeln ihren Inhalt in <Shell>…</Shell>.
import './styles.css';
import { ASSET_URLS, resolveSlotImage } from '../../../lib/render/resolve-images';

interface Props { content: any; client: string }
const { content: c, client } = Astro.props;

const img = (ref?: string) => (ref ? resolveSlotImage(ASSET_URLS, client, ref) ?? undefined : undefined);
const telHref: string =
  (c.nav ?? []).find((n: any) => String(n.href ?? '').startsWith('tel:'))?.href ?? c.hero?.ctaHref ?? '#';
// Header zeigt nur die Anker-Links (#… oder /#…); tel + echte Routen (/karriere) nicht.
const headerLinks = (c.nav ?? []).filter((n: any) => String(n.href ?? '').includes('#'));
---
<div class="blessing-od-site">
  <header class="site-header" id="top" data-section="nav">
    <nav class="nav" aria-label="Hauptnavigation">
      <a class="nav__brand" href="/" aria-label={`${c.brand} — Startseite`}>
        <img src={img(c.logo)} alt={c.logoAlt} />
      </a>
      <div class="nav__links" id="navlinks">
        {headerLinks.map((n: any) => <a href={n.href}>{n.label}</a>)}
        <a class="btn nav__cta" href={telHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Anrufen
        </a>
      </div>
      <button class="nav__toggle" id="navtoggle" aria-label="Menü öffnen" aria-expanded="false" aria-controls="navlinks">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </nav>
  </header>

  <slot />

  <footer class="footer" data-section="footer">
    <div class="footer__inner">
      <div class="footer__brand">
        <img src={img(c.logo)} alt={c.brand} />
        <span class="footer__note">{c.footerNote}</span>
      </div>
      <div class="footer__links">
        {(c.nav ?? []).map((n: any) => <a href={n.href}>{n.label}</a>)}
      </div>
    </div>
  </footer>
</div>

<script>
  (function () {
    'use strict';
    var toggle = document.getElementById('navtoggle');
    var links = document.getElementById('navlinks');
    if (toggle && links) {
      var t = toggle; var l = links;
      t.addEventListener('click', function () {
        var open = l.classList.toggle('is-open');
        t.setAttribute('aria-expanded', open ? 'true' : 'false');
        t.setAttribute('aria-label', open ? 'Menü schließen' : 'Menü öffnen');
      });
      l.addEventListener('click', function (e) {
        var target = e.target as HTMLElement | null;
        if (target && target.closest('a')) {
          l.classList.remove('is-open');
          t.setAttribute('aria-expanded', 'false');
        }
      });
    }
    var header = document.querySelector('.blessing-od-site .site-header') as HTMLElement | null;
    if (header) {
      var h = header;
      var onScroll = function () {
        if (window.scrollY > 8) h.classList.add('is-scrolled');
        else h.classList.remove('is-scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var items = document.querySelectorAll('.blessing-od-site [data-reveal]');
    if (reduce || !('IntersectionObserver' in window)) {
      items.forEach(function (el) { el.classList.add('is-in'); });
    } else {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) { en.target.classList.add('is-in'); io.unobserve(en.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      items.forEach(function (el) { io.observe(el); });
    }
  })();
</script>
