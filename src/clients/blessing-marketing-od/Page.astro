---
import { ASSET_URLS, resolveSlotImage } from '../../lib/render/resolve-images';
import Shell from './_shell/Shell.astro';

// blessing-marketing-od — bespoke Astro-Port des finalisierten Open-Design
// Blessing-Marketing Landingpage-Designs (photo-led / full-bleed). Header/Footer/
// Tokens/Chrome-CSS + Script leben jetzt im geteilten Shell (_shell/); diese Datei
// liefert nur die Home-Sektionen in den <Shell>-Slot. Fakten aus c.* (de.json).

interface Props { content: any; client: string }
const { content: c, client } = Astro.props;

const img = (ref?: string) => (ref ? resolveSlotImage(ASSET_URLS, client, ref) ?? undefined : undefined);

// Logos: erste 4 Einträge sind die quadratischen/runden Badges, der Rest läuft
// als Marquee. Treu zur layout.html-Aufteilung (Badges vs. zwei Marquee-Reihen).
const logoItems: any[] = c.logos?.items ?? [];
const badges = logoItems.slice(0, 4);
const marquee = logoItems.slice(4);
const half = Math.ceil(marquee.length / 2);
const marqueeRow1 = marquee.slice(0, half);
const marqueeRow2 = marquee.slice(half);

const services: any[] = c.services?.items ?? [];
const stats: any[] = c.stats?.items ?? [];
const cases: any[] = c.cases?.items ?? [];
const people = (c.people?.items ?? [])[0];
const testimonials: any[] = c.testimonials?.items ?? [];

// Google-Maps-Routen-Link aus der Adresse bauen.
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(c.map?.address ?? '')}`;
---

<Shell content={c} client={client}>
  <main>

    <!-- ============ HERO ============ -->
    <section class="hero" data-section="hero" id="start">
      <img class="hero__img" src={img(c.hero.image)} alt={c.hero.imageAlt} />
      <div class="hero__scrim"></div>
      <div class="hero__inner">
        <p class="eyebrow">{c.hero.eyebrow}</p>
        <h1 class="hero__title">{c.hero.title}</h1>
        <p class="hero__sub">{c.hero.subtitle}</p>
        <div class="hero__actions">
          <a class="btn" href={c.hero.ctaHref}>
            {c.hero.ctaLabel}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ LOGOS ============ -->
    <section class="section" data-section="logos">
      <div class="wrap">
        <div class="logos__head" data-reveal>
          <p class="eyebrow">{c.logos.eyebrow}</p>
          <h2 class="logos__title">{c.logos.title}</h2>
        </div>

        <div class="badges" data-reveal>
          {badges.map((b: any, i: number) => (
            <img class={i === 3 ? 'badge--round' : undefined} src={img(b.src)} alt={b.alt} />
          ))}
        </div>

        <div class="marquee" aria-label="Kundenlogos">
          <div class="marquee__row">
            <div class="marquee__track">
              {marqueeRow1.map((l: any) => <img src={img(l.src)} alt={l.alt} />)}
              {marqueeRow1.map((l: any) => <img src={img(l.src)} alt="" aria-hidden="true" />)}
            </div>
          </div>
          <div class="marquee__row marquee__row--rev">
            <div class="marquee__track">
              {marqueeRow2.map((l: any) => <img src={img(l.src)} alt={l.alt} />)}
              {marqueeRow2.map((l: any) => <img src={img(l.src)} alt="" aria-hidden="true" />)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section class="section section--alt" id="leistungen" data-section="services">
      <div class="wrap">
        <div data-reveal>
          <p class="eyebrow">{c.services.eyebrow}</p>
          <h2 class="section-title">{c.services.title}</h2>
        </div>
        <div class="services__grid">
          {services.map((s: any, i: number) => (
            <div class="service" data-reveal>
              <span class="service__num">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="service__title">{s.title}</h3>
              <p class="service__desc">{s.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ STATS ============ -->
    <section class="section stats" data-section="stats">
      <div class="wrap">
        <div data-reveal>
          <p class="eyebrow">{c.stats.eyebrow}</p>
          <h2 class="stats__title">{c.stats.title}</h2>
        </div>
        <div class="stats__grid">
          {stats.map((s: any) => (
            <div class="stat" data-reveal>
              <div class="stat__value">{s.value}</div>
              <div class="stat__label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CASES ============ -->
    <section class="section" id="ergebnisse" data-section="cases">
      <div class="wrap">
        <div class="cases__head" data-reveal>
          <div>
            <p class="eyebrow">{c.cases.eyebrow}</p>
            <h2 class="section-title">{c.cases.title}</h2>
          </div>
        </div>

        <div class="cases__list">
          {cases.map((cs: any, i: number) => (
            <article class="case" data-reveal>
              <header>
                <span class="case__index">Case {String(i + 1).padStart(2, '0')}</span>
                <h3 class="case__metric">{cs.metric}</h3>
                <div class="case__client">
                  {cs.logo && <img class="case__logo" src={img(cs.logo)} alt={cs.logoAlt} />}
                  <span class="case__client-name">{cs.client}</span>
                  {cs.href && (
                    <a class="case__visit" href={cs.href} target="_blank" rel="noopener">
                      Website
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8"/></svg>
                    </a>
                  )}
                </div>
              </header>
              <div class="case__body">
                <div class="case__compare">
                  <div class="case--before">
                    <p class="compare__col-title">Ausgangssituation</p>
                    <ul class="compare__list">
                      {(cs.situation ?? []).map((item: string) => (
                        <li><span class="mark mark--neg"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8"/></svg></span>{item}</li>
                      ))}
                    </ul>
                  </div>
                  <div class="case--after">
                    <p class="compare__col-title">Ergebnis</p>
                    <ul class="compare__list">
                      {(cs.result ?? []).map((item: string) => (
                        <li><span class="mark mark--pos"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8.5l3.5 3.5L13 4"/></svg></span>{item}</li>
                      ))}
                    </ul>
                  </div>
                </div>
                {cs.image && (
                  <figure class="case__figure">
                    <img src={img(cs.image)} alt={cs.imageAlt} loading="lazy" />
                  </figure>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ ABOUT ============ -->
    <section class="section section--alt" data-section="about">
      <div class="wrap">
        <div class="about__grid">
          <div data-reveal>
            <p class="eyebrow">{c.about.eyebrow}</p>
            <h2 class="about__title">{c.about.title}</h2>
          </div>
          <div class="about__body" data-reveal>
            {(c.about.paragraphs ?? []).map((p: string) => <p>{p}</p>)}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PEOPLE ============ -->
    <section class="people" data-section="people">
      <div class="people__media">
        {people?.image && <img src={img(people.image)} alt={people.imageAlt} />}
      </div>
      <div class="people__content" data-reveal>
        <p class="eyebrow">{c.people.eyebrow}</p>
        <p class="people__lead">{c.people.title}</p>
        {people && <div class="people__name">{people.name}</div>}
        {people?.role && <div class="people__role">{people.role}</div>}
        <div class="people__bar"></div>
      </div>
    </section>

    <!-- ============ TESTIMONIALS ============ -->
    <section class="section" id="referenzen" data-section="testimonials">
      <div class="wrap">
        <div data-reveal>
          <p class="eyebrow">{c.testimonials.eyebrow}</p>
          <h2 class="section-title">{c.testimonials.title}</h2>
        </div>
        <div class="quotes">
          {testimonials.map((t: any) => (
            <blockquote class="quote" data-reveal>
              <div class="quote__mark" aria-hidden="true">&ldquo;</div>
              <p class="quote__text">{t.quote}</p>
              <div class="quote__by">
                <div class="quote__author">{t.author}</div>
                {t.role && <div class="quote__role">{t.role}</div>}
              </div>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CTA ============ -->
    <section class="section cta" data-section="cta">
      <div class="wrap" data-reveal>
        <h2 class="cta__title">{c.cta.title}</h2>
        <p class="cta__sub">{c.cta.subtitle}</p>
        <a class="btn btn--light" href={c.cta.ctaHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {c.cta.ctaLabel}
        </a>
      </div>
    </section>

    <!-- ============ MAP ============ -->
    <section class="section section--alt" data-section="map">
      <div class="wrap">
        <div class="map__grid">
          <div data-reveal>
            <p class="eyebrow">{c.map.title}</p>
            <h2 class="map__title">{c.map.title}</h2>
            <div class="map__addr">
              <span class="map__pin">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <span>{c.map.address}</span>
            </div>
            <div class="map__route">
              <a class="btn btn--ghost" href={mapsHref} target="_blank" rel="noopener">
                Route planen
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>
          <div class="map__card" data-reveal aria-hidden="true">
            <div class="map__pin-float"></div>
            <div class="map__chip">{c.map.address}</div>
          </div>
        </div>
      </div>
    </section>

  </main>
</Shell>
