---
import type { LookPreset } from '../../lib/theme/schema';
import { presetToCss } from '../../lib/theme/compile';
import '@fontsource-variable/oswald';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';

interface Props { presets?: LookPreset[] }
const { presets = [] } = Astro.props;
const css = presets.map(presetToCss).join('\n');
---
<style is:global set:html={css}></style>
